{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "TestScanner-Properties",
          "version": "1.0.0",
          "rules": [
            {
              "id": "path-traversal",
              "shortDescription": { "text": "Path Traversal" }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "path-traversal",
          "level": "warning",
          "message": { "text": "Path traversal vulnerability" },
          "properties": {
            "CweIDs": ["CWE-22"],
            "stigIds": ["V-222609"]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/files.py" },
                "region": { "startLine": 15 }
              }
            }
          ]
        }
      ]
    }
  ]
}
