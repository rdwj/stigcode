{
  "version": "2.1.0",
  "$schema": "http://json.schemastore.org/sarif-2.1.0-rtm.4",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Semgrep",
          "version": "1.48.0",
          "rules": [
            {
              "id": "sql-injection",
              "shortDescription": { "text": "SQL injection vulnerability" },
              "properties": { "cweIds": [89] }
            },
            {
              "id": "xss-reflected",
              "shortDescription": { "text": "Reflected cross-site scripting" },
              "properties": { "cweIds": [79] }
            },
            {
              "id": "hardcoded-key",
              "shortDescription": { "text": "Hardcoded cryptographic key" },
              "properties": { "cweIds": [798] }
            }
          ]
        }
      },
      "invocations": [
        {
          "startTimeUtc": "2025-02-01T10:00:00Z",
          "executionSuccessful": true
        }
      ],
      "results": [
        {
          "ruleId": "sql-injection",
          "level": "error",
          "message": { "text": "SQL injection via unsanitized user input in query." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/app.py" },
                "region": { "startLine": 42 }
              }
            }
          ]
        },
        {
          "ruleId": "xss-reflected",
          "level": "warning",
          "message": { "text": "Reflected XSS: user-controlled value rendered without escaping." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/views.py" },
                "region": { "startLine": 88 }
              }
            }
          ]
        },
        {
          "ruleId": "hardcoded-key",
          "level": "warning",
          "message": { "text": "Hardcoded cryptographic key found in source." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/config.py" },
                "region": { "startLine": 12 }
              }
            }
          ]
        }
      ]
    }
  ]
}
